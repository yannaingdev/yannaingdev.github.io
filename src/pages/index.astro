    <script>
      (function () {
        const modal = document.getElementById("gallery-modal");
        const mainImg = document.getElementById("gallery-main-img");
        const thumbs = document.getElementById("gallery-thumbs");
        const closeBtn = modal?.querySelector(".gallery-close");
        const backdrop = modal?.querySelector(".gallery-backdrop");

        function openGallery(images) {
          if (!modal || !mainImg || !thumbs) return;
          thumbs.innerHTML = "";
          images.forEach((src, idx) => {
            const thumb = document.createElement("button");
            thumb.className = "gallery-thumb";
            thumb.setAttribute("aria-label", `Project image ${idx + 1}`);
            thumb.innerHTML = `<img src=\"${src}\" alt=\"Project thumbnail ${idx + 1}\" />`;
            thumb.addEventListener("click", () => setActive(src, thumb));
            thumbs.appendChild(thumb);
            if (idx === 0) setActive(src, thumb);
          });
          modal.classList.add("open");
          modal.setAttribute("aria-hidden", "false");
        }

        function setActive(src, thumbEl) {
          mainImg.src = src;
          thumbs.querySelectorAll(".gallery-thumb").forEach((el) => el.classList.remove("active"));
          thumbEl.classList.add("active");
        }

        function closeGallery() {
          if (!modal) return;
          modal.classList.remove("open");
          modal.setAttribute("aria-hidden", "true");
        }

        document.querySelectorAll(".project-card").forEach((card) => {
          const imagesAttr = card.getAttribute("data-images");
          if (!imagesAttr) return;
          const images = imagesAttr
            .split(",")
            .map((s) => s.trim())
            .filter(Boolean);

          const media = card.querySelector(".project-media");
          if (media) {
            media.addEventListener("click", () => openGallery(images));
          }
        });

        closeBtn?.addEventListener("click", closeGallery);
        backdrop?.addEventListener("click", closeGallery);
        document.addEventListener("keyup", (e) => {
          if (e.key === "Escape") closeGallery();
        });
      })();
    </script>
    <script type="module">
      // Inline "View more" toggles for summaries (per-card, no layout shift across cards)
      document.querySelectorAll(".view-more-inline").forEach((btn) => {
        const targetId = btn.getAttribute("data-target");
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) return;
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          const isCollapsed = target.classList.contains("clamp");
          if (isCollapsed) {
            target.classList.remove("clamp");
            btn.textContent = "View less";
          } else {
            target.classList.add("clamp");
            btn.textContent = "View more";
          }
        });
      });
      const scrollBtn = document.getElementById("scrollTopBtn");
      if (scrollBtn) {
        const toggleScrollBtn = () => {
          if (window.scrollY > 280) {
            scrollBtn.classList.add("show");
          } else {
            scrollBtn.classList.remove("show");
          }
        };
        window.addEventListener("scroll", toggleScrollBtn, { passive: true });
        toggleScrollBtn();
        scrollBtn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    </script>
